{
  "name": "@dev-sync/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate --schema=./prisma/schema.prisma && npx tsc -p ./tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "npx prisma migrate deploy --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "socket.io": "^4.7.5",
    "yjs": "^13.6.18",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
